# Keep repo focused on agent-monitor project
*
!/.gitignore
!/agent-monitor/
!/agent-monitor/**
!/.github/
!/.github/**

# Exclude heavy/generated artifacts inside app
agent-monitor/app/node_modules/
agent-monitor/app/dist/
agent-monitor/app/dist-mobile/
agent-monitor/app/electron-dist/
agent-monitor/app/electron-repack-*/
agent-monitor/app/android/.gradle/
agent-monitor/app/android/build/
agent-monitor/app/android/app/build/
agent-monitor/app/release-assets/

# Exclude binary artifacts inside agent
agent-monitor/agent/releases/cluster-agent-*
agent-monitor/agent/sc-out.txt

# Misc
.specstory/
.vscode/
*.log

# Sensitive files
agent-monitor/agent/releases/agent-install.local.bat
agent-monitor/app/android/signing-credentials.local.txt
agent-monitor/app/android/keystore/*.jks
agent-monitor/app/android/keystore/*.keystore

# Local binaries
agent-monitor/agent/*.exe
agent-monitor/agent/*.out

# Local icon temp
agent-monitor/app/build/
